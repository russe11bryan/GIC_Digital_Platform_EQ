{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "./backend/Dockerfile",
    "context": "."
  },
  "deploy": {
    "startCommand": "dotnet CafeEmployeeManager.Api.dll",
    "restartPolicyCondition": "on-failure",
    "restartPolicyMaxRetryCount": 5
  }
}
