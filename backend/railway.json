{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "buildCommand": "dotnet build -c Release",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "startCommand": "dotnet CafeEmployeeManager.Api.dll",
    "numReplicas": 1,
    "restartPolicyMaxRetries": 3
  }
}
